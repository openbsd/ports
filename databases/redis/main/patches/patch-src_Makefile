Changes in this file:
- do not use -funwind-tables and -latomic on armv7
- run tests with datasize, fds, stacksize and processes at the hard limit

Index: src/Makefile
--- src/Makefile.orig
+++ src/Makefile
@@ -84,11 +84,6 @@ ifeq ($(uname_S),Linux)
