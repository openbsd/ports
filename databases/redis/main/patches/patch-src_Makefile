-ifneq (,$(findstring armv,$(uname_M)))
-        FINAL_LIBS+=-latomic
-endif
-
 ifeq ($(uname_S),SunOS)
 	# SunOS
 	ifeq ($(findstring -m32,$(FINAL_CFLAGS)),)
@@ -509,7 +499,7 @@ distclean: clean
 .PHONY: distclean
 
 test: $(REDIS_SERVER_NAME) $(REDIS_CHECK_AOF_NAME) $(REDIS_CLI_NAME) $(REDIS_BENCHMARK_NAME) module_tests
