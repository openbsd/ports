Subject: [PATCH] vcard-export: Adapt to evolution-data-server 3.59.1 EVCard API changes

Index: meson.build
--- meson.build.orig
+++ meson.build
@@ -52,6 +52,9 @@ libadwaita_dep = dependency('libadwaita-1', version: '
 # E-D-S
 libebook = dependency('libebook-1.2', version: '>=' + min_eds_version)
