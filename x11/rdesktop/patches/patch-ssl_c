@@ -41,7 +42,11 @@ rdssl_sha1_update(RDSSL_SHA1 * sha1, uint8 * data, uin
 void
 rdssl_sha1_final(RDSSL_SHA1 * sha1, uint8 * out_data)
 {
+#if NETTLE_VERSION_MAJOR > 3
+	sha1_digest(sha1, out_data);
+#else
 	sha1_digest(sha1, SHA1_DIGEST_SIZE, out_data);
+#endif
 }
 
