-#define _XOPEN_SOURCE /* feature test macro for fsync */
+/* #define _POSIX_SOURCE */ /* feature test macro for fileno */
+/* #define _XOPEN_SOURCE */ /* feature test macro for fsync */
 
 #include "config.h"
 #include "debug.h"
