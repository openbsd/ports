+fi
+
+   if test "$druntime_target_cpu_parsed" = "riscv64"; then
+  DRUNTIME_CPU_RISCV64_TRUE=
+  DRUNTIME_CPU_RISCV64_FALSE='#'
+else
+  DRUNTIME_CPU_RISCV64_TRUE='#'
+  DRUNTIME_CPU_RISCV64_FALSE=
+fi
+
    if test "$druntime_target_cpu_parsed" = "x86"; then
   DRUNTIME_CPU_X86_TRUE=
   DRUNTIME_CPU_X86_FALSE='#'
@@ -15196,7 +15222,9 @@ fi
     aarch64* | \
     arm* | \
     i[34567]86|x86_64 | \
-    powerpc)
+    sparc64* | \
+    riscv64* | \
