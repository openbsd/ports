Upstream handles Octeon only for Linux targets; the generic -elf*
target still needs traditional MIPS linker emulations.

Index: ld/configure.tgt
--- ld/configure.tgt.orig
+++ ld/configure.tgt
@@ -557,6 +557,14 @@ mips64*el-ps2-elf*)	targ_emul=elf32lr5900n32
 mips*el-ps2-elf*)	targ_emul=elf32lr5900
 			targ_extra_libpath=elf32lr5900n32
 			;;
+mipsisa64*el-*-elf*)	targ_emul=elf32ltsmip
+			targ_extra_emuls="elf32btsmip elf32ltsmipn32 elf64ltsmip elf32btsmipn32 elf64btsmip"
+			targ_extra_libpath=$targ_extra_emuls
+			;;
+mipsisa64*-*-elf*)	targ_emul=elf32btsmip
+			targ_extra_emuls="elf32ltsmip elf32btsmipn32 elf64btsmip elf32ltsmipn32 elf64ltsmip"
+			targ_extra_libpath=$targ_extra_emuls
+			;;
 mips*el-*-elf*)		targ_emul=elf32elmip
 			;;
 mips*-*-elf* | mips*-*-rtems*)
