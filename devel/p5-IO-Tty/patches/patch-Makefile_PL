Fix detection of openpty and strlcpy with gcc.
To declare strlcpy _BSD_SOURCE must be set.
gcc 4 does not know __has_include()
openpty needs termios.h

Index: Makefile.PL
--- Makefile.PL.orig
+++ Makefile.PL
@@ -160,6 +160,11 @@ foreach my $f (sort keys %funcs) {
 #define __BSD_VISIBLE 1
 #endif
 #endif
+#ifdef __OpenBSD__
+#ifndef _BSD_SOURCE
+#define _BSD_SOURCE
+#endif
+#endif
 
 #include <stdio.h>
 #include <stdlib.h>
@@ -169,17 +174,8 @@ foreach my $f (sort keys %funcs) {
 #include <fcntl.h>
 
 /* Try platform-specific headers for openpty and friends */
-#if defined(__has_include)
-#  if __has_include(<pty.h>)
-#    include <pty.h>
-#  endif
-#  if __has_include(<libutil.h>)
-#    include <libutil.h>
-#  endif
-#  if __has_include(<util.h>)
+#    include <termios.h>
 #    include <util.h>
-#  endif
-#endif
 
 int
 main ()
