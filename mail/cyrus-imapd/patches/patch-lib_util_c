 #define XOPENDIR_NOSYNC 2
-static int xopendirpath(const char *path, int flags)
+static int xopendirpath(const char *path_arg, int flags)
 {
+    /* Own our copy of the path.  basename(3) and dirname(3) may return
+     * pointers into shared, static, per-call storage (e.g. on OpenBSD),
+     * and the recursive xopendir() call below invokes dirname().  If
+     * path_arg aliased that storage it would be clobbered mid-function,
+     * making us create the wrong directory component. */
+    char *path = xstrdup(path_arg);
+
 #if defined(O_DIRECTORY)
     int dirfd = open(path, O_RDONLY|O_DIRECTORY, 0600);
 #else
