 #endif
-    if (dirfd >= 0) return dirfd; // exists, we're good
-    if (!(flags & XOPENDIR_CREATE)) return dirfd; // not creating? Bail
+    if (dirfd >= 0) { free(path); return dirfd; } // exists, we're good
+    if (!(flags & XOPENDIR_CREATE)) { free(path); return dirfd; } // not creating? Bail
 
     int parentfd = xopendir(path, flags);
-    if (parentfd < 0) return parentfd; // failed, can't get further
+    if (parentfd < 0) { free(path); return parentfd; } // failed, can't get further
 
